pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Building the Project......'
                bat '"D:\Jenkins\\cmd.exe" /c echo Build stage running'
            }
        }

        stage('Test') {
            steps {
                bat '"D:\Jenkins\\cmd.exe" /c echo Test stage running'
            }
        }

        stage('Compile') {
            steps {
                bat '"D:\Jenkins\\cmd.exe" /c echo Compile stage running'
            }
        }

        stage('Deploy') {
            steps {
                bat '"D:\Jenkins\\cmd.exe" /c echo Deploy stage running'
            }
        }
    }
}