pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out source code'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo 'Build using Maven Wrapper'
                bat '"C:\\Windows\\System32\\cmd.exe" /c mvnw.cmd clean compile'
            }
        }

        stage('Test') {
            steps {
                echo 'Run automation tests'
                bat '"C:\\Windows\\System32\\cmd.exe" /c mvnw.cmd test'
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished'
        }
        success {
            echo 'Automation executed successfully'
        }
        failure {
            echo 'Automation failed'
        }
    }
}
