pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Building the Project...'
                powershell 'Write-Output "Build stage running"'
            }
        }

        stage('Test') {
            steps {
                powershell 'Write-Output "Test stage running"'
            }
        }

        stage('Compile') {
            steps {
                powershell 'Write-Output "Compile stage running"'
            }
        }

        stage('Deploy') {
            steps {
                powershell 'Write-Output "Deploy stage running"'
            }
        }
    }
}